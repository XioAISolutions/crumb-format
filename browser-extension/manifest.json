{
  "manifest_version": 3,
  "name": "CRUMB — AI Handoff Format",
  "version": "1.0.0",
  "description": "Right-click any AI chat to generate a structured CRUMB handoff",
  "permissions": ["contextMenus", "clipboardWrite", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
