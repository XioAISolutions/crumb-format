      "--- BEGIN CRUMB ---",
      "v=1",
      "kind=log",
      "title=${1:Session Log}",
      "source=${2:source-tool}",
      "created=${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
      "status=active",
      "---",
      "",
      "[summary]",
      "${3:What happened in this session.}",
      "",
      "[changes]",
      "- ${4:Change 1}",
      "- ${5:Change 2}",
      "",
      "[decisions]",
      "- ${6:Decision made and rationale}",
      "",
      "[issues]",
      "- ${7:Open issues or blockers}",
      "",
      "[next]",
