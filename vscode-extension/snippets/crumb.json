{
  "Task Crumb": {
    "prefix": "task",
    "body": [
      "--- BEGIN CRUMB ---",
      "v=1",
      "kind=task",
      "title=${1:Task Title}",
      "source=${2:source-tool}",
      "target=${3:target-tool}",
      "created=${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
      "status=active",
      "---",
      "",
      "[goal]",
      "${4:Describe the task objective.}",
      "",
      "[context]",
      "- ${5:Relevant background}",
      "",
      "[steps]",
      "- ${6:Step 1}",
      "- ${7:Step 2}",
      "",
      "[constraints]",
      "- ${8:Constraints or requirements}",
      "",
      "[done-when]",
      "- ${9:Acceptance criteria}",
      "",
      "--- END CRUMB ---"
    ],
    "description": "Full CRUMB task handoff template"
  },
  "Memory Crumb": {
    "prefix": "mem",
    "body": [
      "--- BEGIN CRUMB ---",
      "v=1",
      "kind=mem",
      "title=${1:Memory Title}",
      "source=${2:source-tool}",
      "created=${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
      "status=active",
      "---",
      "",
      "[summary]",
      "${3:Brief summary of what was learned or decided.}",
      "",
      "[details]",
      "- ${4:Detail 1}",
      "- ${5:Detail 2}",
      "",
      "[related]",
      "- ${6:Related references}",
      "",
      "--- END CRUMB ---"
    ],
    "description": "Full CRUMB memory template"
  },
  "Map Crumb": {
