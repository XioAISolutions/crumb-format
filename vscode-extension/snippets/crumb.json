      "created=${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
      "status=active",
      "---",
      "",
      "[overview]",
      "${3:High-level project description.}",
      "",
      "[structure]",
      "- ${4:src/ — source code}",
      "- ${5:tests/ — test files}",
      "",
      "[conventions]",
      "- ${6:Coding conventions and patterns}",
      "",
      "[stack]",
      "- ${7:Languages, frameworks, tools}",
      "",
      "[entry-points]",
      "- ${8:Key entry points}",
      "",
      "--- END CRUMB ---"
    ],
    "description": "Full CRUMB project map template"
  },
